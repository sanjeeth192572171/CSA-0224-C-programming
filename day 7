29. Write a C program to find all unique
quadruplets in an array of sum up to a
given value.
#include <stdio.h>

int main() {
    int arr[] = {1, 2, 3, 4, 5, 6};
    int n = 6;
    int target = 10;
    int i, j, k, l;

    printf("Quadruplets with sum %d are:\n", target);

    for(i = 0; i < n; i++) {
        for(j = i + 1; j < n; j++) {
            for(k = j + 1; k < n; k++) {
                for(l = k + 1; l < n; l++) {
                    if(arr[i] + arr[j] + arr[k] + arr[l] == target) {
                        printf("%d %d %d %d\n",
                               arr[i], arr[j], arr[k], arr[l]);
                    }
                }
            }
        }
    }
    return 0;
}
30.Write a C program to rotate an array to the left by one position.
#include <stdio.h>

int main() {
    int arr[] = {10, 20, 30, 40, 50};
    int n = 5;
    int i, first;

    first = arr[0];   // store first element

    for(i = 0; i < n - 1; i++) {
        arr[i] = arr[i + 1];
    }
    arr[n - 1] = first;  // place first element at last
    printf("Array after left rotation:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    return 0;
}
