5.insert an element to the given position
#include <stdio.h>
int main(){
int arr[10],pos,n, i, value;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    printf("Enter %d elements:\n", n);
    for(i=1;i<=n;i++){
    	scanf("%d",&arr[i]);}
    	

    printf("Enter position to insert (1 to %d): ", n+1);
    scanf("%d",&pos);
    printf("Enter value to insert: ");
    scanf("%d", &value);
    // Shift elements
    for(i = n; i >= pos; i--) {
        arr[i] = arr[i-1];
    }
    // Insert value
    arr[pos-1] = value;
    n++;
    // Print new array
    printf("Array after insertion:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}

