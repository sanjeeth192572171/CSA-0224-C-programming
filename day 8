5. Write a program to toggle the case of each character in a string.
#include <stdio.h>
#include <ctype.h>
int main(){
    char s[]="HeLLo"; int i;
    for(i=0;s[i]!='\0';i++){
        if(islower(s[i])) s[i]=toupper(s[i]);
        else if(isupper(s[i])) s[i]=tolower(s[i]);
    }
    printf("%s",s);
    return 0;
}
