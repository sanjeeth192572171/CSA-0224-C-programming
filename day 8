36. C program to search a number using binary search.
#include <stdio.h>
int main(){
int a[]={1,2,3,4,5},low=0,high=4,mid,key=4;
while(low<=high){
mid=(low+high)/2;
if(a[mid]==key){ printf("Found"); break; }
else if(a[mid]<key) low=mid+1;
else high=mid-1;}
return 0;}
37. C program for sorting an array of n numbers using bubble sort.
#include <stdio.h>
int main(){
int a[]={5,1,4,2,3},i,j,t;
for(i=0;i<4;i++)
for(j=0;j<4-i;j++)
if(a[j]>a[j+1]){t=a[j];a[j]=a[j+1];a[j+1]=t;}
for(i=0;i<5;i++) printf("%d ",a[i]);
return 0;}
