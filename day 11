Q16. Rewrite the strlen() function using only pointer arithmetic — no array indexing, no [] operator.
 
#include <stdio.h>
int myStrlen(char *s) {
    char *p = s;
    while (*p != '\0')
        p++;
    return p - s;
}
int main() {
    char str[] = "Hello";
    printf("Length: %d\n", myStrlen(str));
    return 0;
}
 
 
