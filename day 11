Q23. Write a program that swaps two integers using pointers inside a void swap(int *a, int *b) function.
 
#include <stdio.h>
void swap(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}
int main() {
    int x = 10, y = 20;
    printf("Before: x=%d y=%d\n", x, y);
    swap(&x, &y);
    printf("After : x=%d y=%d\n", x, y);
    return 0;
}
 
 
Q24. Write a program that copies a string from one character array to another using only pointer arithmetic (no strcpy(), no []).
 
#include <stdio.h>
void myCopy(char *dest, char *src) {
    while (*src != '\0') {
        *dest = *src;
        dest++;
        src++;
    }
    *dest = '\0';
}
int main() {
    char src[] = "Hello";
    char dest[20];
    myCopy(dest, src);
    printf("Copied: %s\n", dest);
    return 0;
}
 
 
Q25. Write a program that counts the number of vowels in a string using only pointer traversal (no index, no []).
 
#include <stdio.h>
int countVowels(char *p) {
    int count = 0;
    while (*p != '\0') {
        char c = *p;
        if (c=='a'||c=='e'||c=='i'||c=='o'||c=='u'||
            c=='A'||c=='E'||c=='I'||c=='O'||c=='U')
            count++;
        p++;
    }
    return count;
}
int main() {
    char str[] = "Hello World";
    printf("Vowels: %d\n", countVowels(str));
    return 0;
}
