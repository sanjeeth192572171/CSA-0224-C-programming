Q11. Write a program that demonstrates the difference between *p++ and (*p)++ using two separate integer variables and prints both results.
 
#include <stdio.h>
int main() {
    int a = 10, b = 10;
    int *p1 = &a;
    int *p2 = &b;
    int x = *p1++;   /* value of a, then p1 moves */
    int y = (*p2)++; /* b incremented, b becomes 11 */
    printf("*p1++ : x = %d, a = %d\n", x, a);
    printf("(*p2)++: y = %d, b = %d\n", y, b);
    return 0;
}
 
 
