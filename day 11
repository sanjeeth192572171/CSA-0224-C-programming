Q13. Write a program demonstrating the difference between const int *p (pointer to constant) and int * const p (constant pointer), showing which assignments compile and which do not.
 
#include <stdio.h>
int main() {
    int a = 10, b = 20;
    /* Pointer to constant: cannot change *p, but can change p */
    const int *p1 = &a;
    p1 = &b;           /* allowed */
    /* *p1 = 30;       NOT allowed */
    printf("p1 points to b: %d\n", *p1);
    /* Constant pointer: cannot change p, but can change *p */
    int * const p2 = &a;
    *p2 = 50;          /* allowed */
    /* p2 = &b;        NOT allowed */
    printf("p2 value of a: %d\n", *p2);
    return 0;
}
 
 
