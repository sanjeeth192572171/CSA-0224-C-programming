Q18. Write a menu driven program using structure to perform operations on a library system: Add book, Display all books, Search book by title, Delete book, Exit.

#include <stdio.h>
#include <string.h>
#define MAX 50
struct Book {
    char title[100];
    char author[50];
    float price;
};
struct Book b[MAX];
int count = 0;
void addBook() {
    printf("Enter Title, Author, Price: ");
    scanf("%s %s %f", b[count].title, b[count].author, &b[count].price);
    count++;
    printf("Book added.\n");
}
void displayAll() {
    int i;
    if(count == 0) { printf("No books.\n"); return; }
    for(i = 0; i < count; i++)
        printf("%s %s %.2f\n", b[i].title, b[i].author, b[i].price);
}
void searchBook() {
    char t[100]; int i, found = 0;
    printf("Enter title to search: ");
    scanf("%s", t);
    for(i = 0; i < count; i++)
        if(strcmp(b[i].title, t) == 0) {
            printf("%s %s %.2f\n", b[i].title, b[i].author, b[i].price);
            found = 1; break;
        }
    if(!found) printf("Not found.\n");
}
void deleteBook() {
    char t[100]; int i, j, found = 0;
    printf("Enter title to delete: ");
    scanf("%s", t);
    for(i = 0; i < count; i++)
        if(strcmp(b[i].title, t) == 0) {
            for(j = i; j < count-1; j++) b[j] = b[j+1];
            count--;
            printf("Deleted.\n");
            found = 1; break;
        }
    if(!found) printf("Not found.\n");
}
int main() {
    int choice;
    do {
        printf("\n1.Add 2.Display 3.Search 4.Delete 5.Exit\nChoice: ");
        scanf("%d", &choice);
        switch(choice) {
            case 1: addBook(); break;
            case 2: displayAll(); break;
            case 3: searchBook(); break;
            case 4: deleteBook(); break;
            case 5: printf("Exiting.\n"); break;
            default: printf("Invalid choice.\n");
        }
    } while(choice != 5);
    return 0;
}


Q19. Write a menu driven program using structure to perform operations on a product inventory: Add product, Display all products, Search product by name, Update product price, Exit.

