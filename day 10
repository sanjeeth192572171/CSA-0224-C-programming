#include <string.h>
#define MAX 50
struct Product {
    char name[50];
    int quantity;
    float price;
};
struct Product p[MAX];
int count = 0;
void addProduct() {
    printf("Enter Name, Quantity, Price: ");
    scanf("%s %d %f", p[count].name, &p[count].quantity, &p[count].price);
    count++;
    printf("Product added.\n");
}
void displayAll() {
    int i;
    if(count == 0) { printf("No products.\n"); return; }
    for(i = 0; i < count; i++)
        printf("%s %d %.2f\n", p[i].name, p[i].quantity, p[i].price);
