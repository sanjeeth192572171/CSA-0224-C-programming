    char n[50]; int i, found = 0;
    printf("Enter name to search: ");
    scanf("%s", n);
    for(i = 0; i < count; i++)
        if(strcmp(p[i].name, n) == 0) {
            printf("%s %d %.2f\n", p[i].name, p[i].quantity, p[i].price);
            found = 1; break;
        }
