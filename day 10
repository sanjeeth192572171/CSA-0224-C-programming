Q15. Write a program to sort N students by their marks in descending order using array of structures.

#include <stdio.h>
struct Student {
    char name[50];
    float marks;
};
int main() {
    int n, i, j;
    struct Student temp;
    printf("Enter number of students: ");
    scanf("%d", &n);
    struct Student s[n];
    for(i = 0; i < n; i++) {
        printf("Enter Name and Marks: ");
        scanf("%s %f", s[i].name, &s[i].marks);
    }
    for(i = 0; i < n-1; i++)
        for(j = 0; j < n-i-1; j++)
            if(s[j].marks < s[j+1].marks) {
                temp = s[j];
                s[j] = s[j+1];
                s[j+1] = temp;
            }
    printf("Sorted Students:\n");
    for(i = 0; i < n; i++)
        printf("%s - %.2f\n", s[i].name, s[i].marks);
    return 0;
}


Q16. Write a menu driven program using structure to perform operations on student records: Add student, Display all students, Search student by roll no, Exit.

#include <stdio.h>
#define MAX 50
struct Student {
    int rollno;
    char name[50];
    float marks;
};
struct Student s[MAX];
int count = 0;
void addStudent() {
    printf("Enter Roll No, Name, Marks: ");
    scanf("%d %s %f", &s[count].rollno, s[count].name, &s[count].marks);
    count++;
    printf("Student added.\n");
}
void displayAll() {
    int i;
    if(count == 0) { printf("No records.\n"); return; }
    for(i = 0; i < count; i++)
        printf("%d %s %.2f\n", s[i].rollno, s[i].name, s[i].marks);
}
void searchByRoll() {
    int r, i, found = 0;
    printf("Enter Roll No to search: ");
    scanf("%d", &r);
    for(i = 0; i < count; i++)
        if(s[i].rollno == r) {
            printf("%d %s %.2f\n", s[i].rollno, s[i].name, s[i].marks);
            found = 1; break;
        }
    if(!found) printf("Not found.\n");
}
int main() {
    int choice;
    do {
        printf("\n1.Add 2.Display 3.Search 4.Exit\nChoice: ");
        scanf("%d", &choice);
        switch(choice) {
            case 1: addStudent(); break;
            case 2: displayAll(); break;
            case 3: searchByRoll(); break;
            case 4: printf("Exiting.\n"); break;
            default: printf("Invalid choice.\n");
        }
    } while(choice != 4);
    return 0;
}


