Q7. Write a function that takes an array pointer and returns the second largest element.
 
#include <stdio.h>
int secondLargest(int *p, int n) {
    int first = -1, second = -1, i;
    for (i = 0; i < n; i++) {
        if (*(p+i) > first) { second = first; first = *(p+i); }
        else if (*(p+i) > second && *(p+i) != first) second = *(p+i);
    }
    return second;
}
int main() {
    int arr[] = {10, 5, 20, 15, 8};
    printf("Second Largest: %d\n", secondLargest(arr, 5));
    return 0;
}
 
 
