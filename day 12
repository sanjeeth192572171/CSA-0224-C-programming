Q2. Write a function to find the largest element in an array using pointer arithmetic.
 
#include <stdio.h>
int largest(int *p, int n) {
    int max = *p;
    int i;
    for (i = 1; i < n; i++)
        if (*(p + i) > max) max = *(p + i);
    return max;
}
