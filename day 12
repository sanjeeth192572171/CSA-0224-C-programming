Q4. Write a function to reverse an array using pointers and print the result.
 
#include <stdio.h>
void reverseArray(int *p, int n) {
    int *start = p;
    int *end = p + n - 1;
    int temp;
    while (start < end) {
        temp = *start;
        *start = *end;
        *end = temp;
        start++; end--;
    }
}
int main() {
    int arr[] = {1, 2, 3, 4, 5};
    int i;
    reverseArray(arr, 5);
    for (i = 0; i < 5; i++) printf("%d ", arr[i]);
    printf("\n");
    return 0;
}
 
 
