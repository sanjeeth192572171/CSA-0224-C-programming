void countEvenOdd(int *p, int n, int *even, int *odd) {
    *even = 0; *odd = 0;
    int i;
    for (i = 0; i < n; i++) {
        if (*(p + i) % 2 == 0) (*even)++;
        else (*odd)++;
    }
