Q30. Write a function that accepts a pointer to a 2D array and checks whether it is a symmetric matrix using pointer notation.
 
#include <stdio.h>
#define N 3
int isSymmetric(int (*p)[N]) {
    int i, j;
    for (i = 0; i < N; i++)
        for (j = 0; j < N; j++)
            if (*(*(p+i)+j) != *(*(p+j)+i)) return 0;
    return 1;
}
int main() {
    int mat[N][N]={{1,2,3},{2,4,5},{3,5,6}};
    if (isSymmetric(mat)) printf("Symmetric\n");
    else printf("Not Symmetric\n");
