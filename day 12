Q21. Write a function to multiply two matrices using pointer notation and store the result in a third matrix.
 
#include <stdio.h>
#define N 2
void multiply(int (*a)[N], int (*b)[N], int (*c)[N]) {
    int i, j, k;
    for (i = 0; i < N; i++)
        for (j = 0; j < N; j++) {
            *(*(c+i)+j) = 0;
            for (k = 0; k < N; k++)
                *(*(c+i)+j) += *(*(a+i)+k) * *(*(b+k)+j);
        }
}
int main() {
    int a[N][N]={{1,2},{3,4}};
    int b[N][N]={{5,6},{7,8}};
    int c[N][N]; int i, j;
    multiply(a, b, c);
    for (i=0;i<N;i++){for(j=0;j<N;j++) printf("%d ",c[i][j]); printf("\n");}
    return 0;
}
 
 
