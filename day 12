Q19. Write a function to remove duplicate elements from an array using pointer arithmetic.
 
#include <stdio.h>
int removeDuplicates(int *p, int n) {
    int i, j, k, newSize = n;
    for (i = 0; i < newSize; i++)
        for (j = i+1; j < newSize; j++)
            if (*(p+i) == *(p+j)) {
                for (k = j; k < newSize-1; k++)
                    *(p+k) = *(p+k+1);
                newSize--; j--;
            }
    return newSize;
}
int main() {
    int arr[] = {1, 2, 2, 3, 4, 3, 5};
    int n = removeDuplicates(arr, 7), i;
    for (i = 0; i < n; i++) printf("%d ", arr[i]);
    printf("\n");
    return 0;
}
 
 
