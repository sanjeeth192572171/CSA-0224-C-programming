Q25. Write a function to merge two sorted arrays into a third sorted array using pointer arithmetic.
 
#include <stdio.h>
void mergeSorted(int *a, int m, int *b, int n, int *c) {
    int i=0, j=0, k=0;
    while (i < m && j < n) {
        if (*(a+i) <= *(b+j)) { *(c+k) = *(a+i); i++; }
        else                  { *(c+k) = *(b+j); j++; }
        k++;
    }
    while (i < m) { *(c+k) = *(a+i); i++; k++; }
    while (j < n) { *(c+k) = *(b+j); j++; k++; }
}
int main() {
    int a[]={1,3,5}, b[]={2,4,6}, c[6], i;
    mergeSorted(a, 3, b, 3, c);
    for (i = 0; i < 6; i++) printf("%d ", c[i]);
    printf("\n");
    return 0;
}
 
 
