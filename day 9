Q10. Convert Celsius to Fahrenheit and vice versa.
#include <stdio.h>

void celsius_to_fahrenheit(float c) {
    float f = (c * 9.0 / 5.0) + 32;
    printf("%.2fC = %.2fF\n", c, f);
}

void fahrenheit_to_celsius(float f) {
    float c = (f - 32) * 5.0 / 9.0;
    printf("%.2fF = %.2fC\n", f, c);
}

int main() {
    float c, f;
    printf("Enter temperature in Celsius: ");
    scanf("%f", &c);
    celsius_to_fahrenheit(c);

    printf("Enter temperature in Fahrenheit: ");
    scanf("%f", &f);
    fahrenheit_to_celsius(f);
    return 0;
}

Q11. Check whether a given string is a palindrome.
#include <stdio.h>
#include <string.h>

void is_palindrome(char s[]) {
    int len = strlen(s);
    int flag = 1;
    for (int i = 0; i < len / 2; i++) {
        if (s[i] != s[len - 1 - i]) {
            flag = 0;
            break;
        }
    }
    if (flag)
        printf("%s is a Palindrome\n", s);
    else
        printf("%s is not a Palindrome\n", s);
}

int main() {
    char s[100];
    printf("Enter a string: ");
    scanf("%s", s);
    is_palindrome(s);
    return 0;
}

Q12. Find the second largest element in a list without sorting.
