Q7. Print all prime numbers between 1 and 100.
#include <stdio.h>

int is_prime(int n) {
    if (n < 2) return 0;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) return 0;
    }
    return 1;
}

void print_primes() {
    printf("Prime numbers between 1 and 100:\n");
    for (int i = 1; i <= 100; i++) {
        if (is_prime(i))
            printf("%d ", i);
    }
    printf("\n");
}

int main() {
    print_primes();
    return 0;
}

Q8. Reverse a string without using built-in reverse functions.
#include <stdio.h>
#include <string.h>

void reverse_string(char s[]) {
    int len = strlen(s);
    char reversed[100];
    for (int i = 0; i < len; i++) {
        reversed[i] = s[len - 1 - i];
    }
    reversed[len] = '\0';
    printf("Reversed String: %s\n", reversed);
}

