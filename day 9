Q22. Reverse Each Word in a Sentence.
#include <stdio.h>
#include <string.h>

void reverse_word(char word[]) {
    int len = strlen(word);
    for (int i = 0; i < len / 2; i++) {
        char temp = word[i];
        word[i] = word[len - 1 - i];
        word[len - 1 - i] = temp;
    }
}

void reverse_each_word(char sentence[]) {
    char word[50];
    int k = 0;
    printf("Reversed Words: ");
    for (int i = 0; sentence[i] != '\0'; i++) {
        if (sentence[i] != ' ') {
            word[k++] = sentence[i];
        } else {
            word[k] = '\0';
            reverse_word(word);
            printf("%s ", word);
            k = 0;
        }
    }
    word[k] = '\0';
    reverse_word(word);
    printf("%s\n", word);
}

int main() {
    char sentence[200];
    printf("Enter a sentence: ");
    gets(sentence);
    reverse_each_word(sentence);
    return 0;
}

Q23. Find the Most Frequent Character in a String.
#include <stdio.h>
#include <string.h>

void most_frequent_char(char s[]) {
    int freq[256] = {0};
    for (int i = 0; s[i] != '\0'; i++) {
        if (s[i] != ' ')
            freq[(int)s[i]]++;
    }
    int max = 0;
    char max_char = s[0];
    for (int i = 0; s[i] != '\0'; i++) {
        if (freq[(int)s[i]] > max) {
            max = freq[(int)s[i]];
            max_char = s[i];
        }
    }
    printf("Most Frequent Character: %c | Count: %d\n", max_char, max);
}

int main() {
    char s[100];
    printf("Enter a string: ");
    scanf("%s", s);
    most_frequent_char(s);
    return 0;
}

Q24. Check if Two Strings are Anagrams.
#include <stdio.h>
#include <string.h>

void are_anagrams(char s1[], char s2[]) {
    int freq[256] = {0};
    for (int i = 0; s1[i] != '\0'; i++) freq[(int)s1[i]]++;
    for (int i = 0; s2[i] != '\0'; i++) freq[(int)s2[i]]--;
    for (int i = 0; i < 256; i++) {
        if (freq[i] != 0) {
            printf("%s and %s are NOT Anagrams\n", s1, s2);
            return;
        }
    }
    printf("%s and %s are Anagrams\n", s1, s2);
}

int main() {
    char s1[100], s2[100];
    printf("Enter first string: ");
    scanf("%s", s1);
    printf("Enter second string: ");
    scanf("%s", s2);
    are_anagrams(s1, s2);
    return 0;
}

Q25. Count Even and Odd Numbers in an Array.
#include <stdio.h>

void count_even_odd(int arr[], int n) {
    int even = 0, odd = 0;
    for (int i = 0; i < n; i++) {
        if (arr[i] % 2 == 0) even++;
        else odd++;
    }
    printf("Even count: %d\n", even);
    printf("Odd count: %d\n", odd);
}

int main() {
    int arr[] = {1, 2, 3, 4, 5, 6, 7, 8};
    int n = sizeof(arr) / sizeof(arr[0]);
    count_even_odd(arr, n);
    return 0;
}
