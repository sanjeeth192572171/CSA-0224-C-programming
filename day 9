Q20. Count Occurrences of a Substring.
#include <stdio.h>
#include <string.h>

void count_substring(char s[], char sub[]) {
    int count = 0;
    int slen = strlen(s), sublen = strlen(sub);
    for (int i = 0; i <= slen - sublen; i++) {
        int match = 1;
        for (int j = 0; j < sublen; j++) {
            if (s[i + j] != sub[j]) { match = 0; break; }
        }
        if (match) count++;
    }
    printf("'%s' appears %d time(s) in '%s'\n", sub, count, s);
}

int main() {
    char s[100], sub[50];
    printf("Enter main string: ");
    scanf("%s", s);
    printf("Enter substring: ");
    scanf("%s", sub);
    count_substring(s, sub);
    return 0;
}

